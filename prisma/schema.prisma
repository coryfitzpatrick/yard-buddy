generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String    @unique
  emailVerified        DateTime?
  image                String?
  passwordHash         String?
  notificationsEnabled Boolean   @default(true)
  lastNotifiedAt       DateTime?
  notifyDaysAhead              Int       @default(3)
  reminderNotificationsEnabled Boolean   @default(true)
  reminderDaysBefore           Int       @default(0)
  gddNotificationsEnabled      Boolean   @default(true)
  gddBestDayReminderDays       Int       @default(0)
  emailNotificationsEnabled    Boolean   @default(true)
  pushNotificationsEnabled     Boolean   @default(true)
  taskPushEnabled              Boolean   @default(false)
  schedulePushEnabled          Boolean   @default(true)
  weatherEmailEnabled          Boolean   @default(true)
  weatherPushEnabled           Boolean   @default(true)
  weatherWidgetCollapsed       Boolean   @default(true)
  createdAt                    DateTime  @default(now())
  plan                 String    @default("trial")
  planStatus           String    @default("trialing")
  trialEndsAt          DateTime?
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  currentPeriodEnd     DateTime?

  // Trial engagement extension — set when user completes the +7 day bonus criteria
  trialEngagementBonusGrantedAt DateTime?

  // Trial nudge idempotency flags
  day5NudgeSentAt   DateTime?
  day10NudgeSentAt  DateTime?
  day14SecondAnalysisPromptSentAt DateTime?

  // Grace period warning idempotency flags
  graceDay14EmailSentAt DateTime?
  graceDay7EmailSentAt  DateTime?
  graceDay2EmailSentAt  DateTime?
  gracePush7SentAt      DateTime?
  gracePush1SentAt      DateTime?
  trialEndedPushSentAt  DateTime?

  cardExpiryWarningSentAt DateTime?
  lastPaymentFailedInvoiceId String?
  termsAcceptedAt      DateTime?
  updatedAt            DateTime  @updatedAt
  accounts             Account[]
  sessions             Session[]
  yards                Yard[]
  passwordResets       PasswordResetToken[]
  emailChangeRequests  EmailChangeRequest[]
  aiUsageEvents        AiUsageEvent[]
  deviceTokens         DeviceToken[]
  biometricRefreshTokens BiometricRefreshToken[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Yard {
  id                 String        @id @default(cuid())
  userId             String
  name               String        @default("My Property")
  slug               String
  zipCode            String
  streetAddress      String?
  city               String?
  state              String?
  latitude           Float?
  longitude          Float?
  lotSqft            Int?
  buildingSqft       Int?
  spreaderType       String?
  spreaderModel      String?
  wateringMinutesPerSession Int?
  mowingHeightInches        Float?
  wateringDays              String[]   @default([])
  wateringTime              String?
  mowingDays                String[]   @default([])
  mowingTime                String?
  archivedAt DateTime?
  weatherRefreshedAt DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections           YardSection[]
  gddRecords         GddRecord[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([userId, archivedAt])
}

model YardSection {
  id            String         @id @default(cuid())
  yardId        String
  name          String         @default("Front Yard")
  slug          String
  areaType      String?
  yardSizeSqft  Int?
  grassType     String         @default("unknown")
  soilPh            Float?
  nitrogenPpm       Float?
  phosphorusPpm     Float?
  potassiumPpm      Float?
  organicMatterPct  Float?
  soilTestSource    String?
  soilTestedAt      DateTime?
  soilMoisture      String?
  notes         String?
  wateringMinutesPerSession Int?
  mowingHeightInches        Float?
  wateringDays              String[]   @default([])
  wateringTime              String?
  mowingDays                String[]   @default([])
  mowingTime                String?
  currentRoutine    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  yard          Yard           @relation(fields: [yardId], references: [id], onDelete: Cascade)
  analyses      LawnAnalysis[]
  tasks         LawnTask[]

  @@unique([yardId, slug])
  @@index([yardId])
}

model LawnAnalysis {
  id            String      @id @default(cuid())
  yardSectionId String
  imageUrls     String[]
  healthScore   Int
  issues        String[]
  summary       String      @db.Text
  rawResponse   String      @db.Text
  wateringSchedule                   String?   @db.Text
  wateringDeviates                   Boolean?
  wateringSuggestedDaysPerWeek       Int?
  wateringSuggestedMinutesPerSession Int?
  wateringRecommendationDismissedAt  DateTime?
  mowingSchedule                     String?   @db.Text
  mowingDeviates                     Boolean?
  mowingSuggestedDaysPerWeek         Int?
  mowingSuggestedHeightInches        Float?
  mowingRecommendationDismissedAt    DateTime?
  createdAt     DateTime    @default(now())
  yardSection   YardSection @relation(fields: [yardSectionId], references: [id], onDelete: Cascade)
  tasks         LawnTask[]

  @@index([yardSectionId, createdAt])
}

model LawnTask {
  id               String        @id @default(cuid())
  yardSectionId    String
  analysisId       String?
  title            String
  description      String        @db.Text
  priority         String        @default("medium")
  status           String        @default("pending")
  scheduledStart   DateTime?
  scheduledEnd     DateTime?
  weatherCondition String?
  overdueNote      String?       @db.Text
  stillWorthDoing  Boolean?
  completedAt      DateTime?
  product          String?
  applicationRate  String?
  spreaderSetting  String?
  taskMode         String?
  productSearchQuery String?
  gddThreshold     String?
  bestDay          DateTime?
  additionalSectionIds String[]  @default([])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  yardSection      YardSection   @relation(fields: [yardSectionId], references: [id], onDelete: Cascade)
  analysis         LawnAnalysis? @relation(fields: [analysisId], references: [id])

  @@index([yardSectionId])
  @@index([analysisId])
  @@index([status, scheduledEnd])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailChangeRequest {
  id        String   @id @default(cuid())
  userId    String
  newEmail  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RateLimitAttempt {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

model GddRecord {
  id               String   @id @default(cuid())
  yardId           String
  year             Int
  cumulativeGdd    Float    @default(0)
  preEmergentFired Boolean  @default(false)
  grubsFired       Boolean  @default(false)
  overseedingFired Boolean  @default(false)
  createdAt        DateTime @default(now())
  lastUpdatedAt    DateTime @updatedAt

  yard Yard @relation(fields: [yardId], references: [id], onDelete: Cascade)

  @@unique([yardId, year])
}

model AiUsageEvent {
  id                     String   @id @default(cuid())
  userId                 String?
  feature                String
  model                  String
  inputTokens            Int      @default(0)
  outputTokens           Int      @default(0)
  cacheReadTokens        Int      @default(0)
  cacheCreationTokens    Int      @default(0)
  costUsd                Decimal  @db.Decimal(10, 6)
  success                Boolean  @default(true)
  errorCode              String?
  createdAt              DateTime @default(now())
  user                   User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model DeviceToken {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  platform     String   // "ios" | "android"
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())
  failureCount Int      @default(0)

  @@index([userId])
}

model BiometricRefreshToken {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String    @unique   // sha256(plaintext token), hex
  deviceFingerprint String?              // informational only: platform + app version + UA hash
  createdAt         DateTime  @default(now())
  revokedAt         DateTime?            // null = active; non-null = revoked

  @@index([userId])
}
