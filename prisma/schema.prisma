generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String    @unique
  emailVerified        DateTime?
  image                String?
  passwordHash         String?
  notificationsEnabled Boolean   @default(true)
  lastNotifiedAt       DateTime?
  notifyDaysAhead              Int       @default(3)
  reminderNotificationsEnabled Boolean   @default(true)
  reminderDaysBefore           Int       @default(0)
  gddNotificationsEnabled      Boolean   @default(true)
  gddBestDayReminderDays       Int       @default(0)
  weatherWidgetCollapsed       Boolean   @default(false)
  createdAt                    DateTime  @default(now())
  plan                 String    @default("trial")
  planStatus           String    @default("trialing")
  trialEndsAt          DateTime?
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  currentPeriodEnd     DateTime?
  pausedUntil          DateTime?
  updatedAt            DateTime  @updatedAt
  accounts             Account[]
  sessions             Session[]
  yards                Yard[]
  passwordResets       PasswordResetToken[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Yard {
  id                 String        @id @default(cuid())
  userId             String
  name               String        @default("My Property")
  zipCode            String
  streetAddress      String?
  city               String?
  state              String?
  latitude           Float?
  longitude          Float?
  lotSqft            Int?
  buildingSqft       Int?
  spreaderType       String?
  spreaderModel      String?
  wateringDaysPerWeek       Int?
  wateringMinutesPerSession Int?
  mowingSchedule            String?
  wateringSchedule          String?
  weatherRefreshedAt DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections           YardSection[]
  gddRecords         GddRecord[]

  @@index([userId])
}

model YardSection {
  id            String         @id @default(cuid())
  yardId        String
  name          String         @default("Front Yard")
  areaType      String?
  yardSizeSqft  Int?
  grassType     String         @default("unknown")
  soilPh            Float?
  nitrogenPpm       Float?
  phosphorusPpm     Float?
  potassiumPpm      Float?
  organicMatterPct  Float?
  soilTestSource    String?
  soilTestedAt      DateTime?
  soilMoisture      String?
  notes         String?
  currentRoutine    String?
  wateringSchedule  String?
  mowingSchedule    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  yard          Yard           @relation(fields: [yardId], references: [id], onDelete: Cascade)
  analyses      LawnAnalysis[]
  tasks         LawnTask[]

  @@index([yardId])
}

model LawnAnalysis {
  id            String      @id @default(cuid())
  yardSectionId String
  imageUrls     String[]
  healthScore   Int
  issues        String[]
  summary       String      @db.Text
  rawResponse   String      @db.Text
  createdAt     DateTime    @default(now())
  yardSection   YardSection @relation(fields: [yardSectionId], references: [id], onDelete: Cascade)
  tasks         LawnTask[]

  @@index([yardSectionId])
}

model LawnTask {
  id               String        @id @default(cuid())
  yardSectionId    String
  analysisId       String?
  title            String
  description      String        @db.Text
  priority         String        @default("medium")
  status           String        @default("pending")
  scheduledStart   DateTime?
  scheduledEnd     DateTime?
  weatherCondition String?
  overdueNote      String?       @db.Text
  stillWorthDoing  Boolean?
  completedAt      DateTime?
  product          String?
  applicationRate  String?
  spreaderSetting  String?
  taskMode         String?
  productSearchQuery String?
  gddThreshold     String?
  bestDay          DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  yardSection      YardSection   @relation(fields: [yardSectionId], references: [id], onDelete: Cascade)
  analysis         LawnAnalysis? @relation(fields: [analysisId], references: [id])

  @@index([yardSectionId])
  @@index([analysisId])
  @@index([status, scheduledEnd])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GddRecord {
  id               String   @id @default(cuid())
  yardId           String
  year             Int
  cumulativeGdd    Float    @default(0)
  preEmergentFired Boolean  @default(false)
  grubsFired       Boolean  @default(false)
  overseedingFired Boolean  @default(false)
  createdAt        DateTime @default(now())
  lastUpdatedAt    DateTime @updatedAt

  yard Yard @relation(fields: [yardId], references: [id], onDelete: Cascade)

  @@unique([yardId, year])
}
