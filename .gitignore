# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# git worktrees
.worktrees/
coverage/

# Validation results
scripts/validation/results/*.json
!scripts/validation/results/baseline.json

# Claude Code local-only files (contains permission allowlist that may cache credentials)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Superpowers brainstorm runtime state (PID files, server logs)
.superpowers/brainstorm/*/state/

# Backup files
*.bak

# Graphify — commit the graph itself for shared "codebase memory" across
# sessions and teammates, but skip the local-only cost ledger and the
# regenerable cache directory (each dev rebuilds these locally).
graphify-out/cost.json
graphify-out/cache/

# Affinity Designer / Photo lock files
*~lock~
